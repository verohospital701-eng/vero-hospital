# Example .env values. DO NOT commit real secrets to source control.

# Local development
NODE_ENV=development
MONGODB_URL_DEVELOPMENT=mongodb://localhost/vero-hospital

# Production (set these on the host / Render dashboard)
# Use your MongoDB Atlas SRV connection string here:
MONGODB_URL_PRODUCTION=mongodb+srv://<username>:<password>@cluster0.mongodb.net/vero-hospital?retryWrites=true&w=majority

# SMTP for outgoing emails (optional)
SENDOR_EMAIL=you@example.com
SENDOR_PASSWORD=your-email-password-or-app-password

# When deployed the host provides PORT; you can set it if required
PORT=4000

# Testing
MONGODB_URL_TEST=mongodb://localhost/testvero-hospital